{
  "name": "lanlink",
  "version": "1.0.0",
  "description": "LAN file transfer and messaging between desktop and mobile devices",
  "main": "dist-electron/main.js",
  "author": "Tapiwa Makandigona <silentics.org@gmail.com>",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "cap:sync": "npm run build && npx cap sync",
    "cap:android": "npm run build && npx cap sync android && npx cap open android",
    "lint": "eslint src/ electron/ --ext .ts,.tsx"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.0",
    "ws": "^8.16.0",
    "bonjour-service": "^1.2.1",
    "uuid": "^9.0.0",
    "clsx": "^2.1.0",
    "@capacitor/core": "^5.7.0",
    "@capacitor/filesystem": "^5.2.0",
    "@capacitor/network": "^5.0.7",
    "@capacitor/device": "^5.0.7",
    "@capacitor/clipboard": "^5.0.7",
    "@capacitor/app": "^5.0.7",
    "lucide-react": "^0.303.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^5.7.0",
    "@capacitor/android": "^5.7.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/ws": "^8.5.10",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.5",
    "wait-on": "^7.2.0"
  }
}
